{
  "telemetry.telemetryLevel": "off",
  "telemetry.feedback.enabled": false,
  "window.titleBarStyle": "native",
  "window.nativeTabs": true,
  "window.restoreWindows": "none",
  "window.newWindowDimensions": "maximized",
  "window.openFilesInNewWindow": "default",
  "window.openFoldersInNewWindow": "on",
  "workbench.editor.enablePreview": true,
  "workbench.statusBar.visible": true,
  "workbench.sideBar.location": "left",
  "workbench.colorTheme": "Solarized Dark",
  "explorer.confirmDragAndDrop": false,
  "editor.folding": true,
  "editor.minimap.enabled": false,
  "editor.multiCursorModifier": "alt",
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "terminal.external.osxExec": "kitty.app",
  "debug.console.historySuggestions": true,
  "diffEditor.renderSideBySide": false,
  "docker.extension.enableComposeLanguageServer": false,
  "files.associations": {
    "*.jake": "javascript"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "javascript.updateImportsOnFileMove.enabled": "never",
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "eslint.alwaysShowStatus": true,
  "eslint.format.enable": true,
  "ionic.defaultPort": 3000,
  "emmet.triggerExpansionOnTab": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "javascriptreact"
  },
  "[dart]": {
    "editor.formatOnSave": false,
    "editor.formatOnType": true,
    "editor.rulers": [
      120
    ],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off",
  },
  "dart.allowAnalytics": false,
  "dart.debugExternalLibraries": true,
  "dart.debugSdkLibraries": true,
  "dart.flutterWebRenderer": "canvaskit",
  "dart.lineLength": 120,
  "dart.previewHotReloadOnSaveWatcher": true,
  "dart.previewLsp": true,
  "mdb.sendTelemetry": false,
  "mdb.confirmRunAll": false,
  "mdb.useDefaultTemplateForPlayground": false,
  "mdb.mcp.server": "prompt",
  "[swift]": {}
}