# ~/.config/shell/path: executed by the command interpreter for login shells.

export PATH="${HOME}/.local/bin:${PATH}"

# Set N prefix
export N_PREFIX="${HOME}/.n"

# $DEV_TOOLS_PATH
export DEV_TOOLS_PATH="${HOME}/dev/tools/bin"

# Add rbenv to $PATH
export PATH="${HOME}/.rbenv/bin:${PATH}"

# Add n to $PATH
export PATH="$N_PREFIX/bin:${PATH}"

# Add "${HOME}/bin" to $PATH
export PATH="${HOME}/bin:${PATH}"

# Add dev tools to $PATH
export PATH="$DEV_TOOLS_PATH:${PATH}"

# Android SDK
export ANDROID_HOME="${HOME}/dev/tools/android-sdk"
export PATH="${PATH}:${ANDROID_HOME}/cmdline-tools/latest:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools"
